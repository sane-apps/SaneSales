  export:
    options_plist: ExportOptions-DevID.plist
    profiles:
      - "com.sanesales.app:SaneSales Developer ID"
      - "com.sanesales.app.widgets:SaneSales Widgets Developer ID"
  archive_extra_args:
    - "-allowProvisioningUpdates"
  dmg:
    volume_icon: Resources/DMGIcon.icns
    file_icon: Resources/DMGIcon.icns
    window_size: "800 400"
    app_icon_pos: "200 185"
    drop_pos: "600 185"

commands:
  verify: ./scripts/SaneMaster.rb verify
  test_mode: ./scripts/SaneMaster.rb tm
  lint: ./scripts/SaneMaster.rb lint
  clean: ./scripts/SaneMaster.rb clean
  launch: ./scripts/SaneMaster.rb launch
  logs: ./scripts/SaneMaster.rb logs

docs:
  - CLAUDE.md
  - README.md
  - DEVELOPMENT.md
  - ARCHITECTURE.md
  - SESSION_HANDOFF.md

mcps:
  - apple-docs
  - context7
  - github
  - xcode

appstore:
  enabled: true
  app_id: "6759010976"
  product_id: "com.sanesales.app.pro.unlock.v2"
  iap_price_usd: "24.99"
  scheme: SaneSales-AppStore
  configuration: Release-AppStore
  platforms: [macos, ios]
  ios_scheme: SaneSalesIOS
  category: public.app-category.finance
  age_rating: "4+"
  copyright: "2026 SaneApps"
  content_rights_declaration: DOES_NOT_USE_THIRD_PARTY_CONTENT
  export_compliance:
    uses_non_exempt_encryption: false
    exemption_reason: "SaneSales does not use non-exempt encryption. It relies on Apple platform security and direct local network requests to the user's configured sales providers."
  privacy_policy_url: "https://sanesales.com/privacy"
  support_url: "https://sanesales.com/support"
  marketing_url: "https://sanesales.com"
  metadata:
    macos:
      subtitle: "Private Revenue Tracker"
      promotional_text: "Track Lemon Squeezy, Gumroad, and Stripe in one private native app. Try demo data first, then unlock Pro for live sales."
      description: >-
        Track Lemon Squeezy, Gumroad, and Stripe revenue in one private native app for indie sellers.

        SaneSales is built for makers who sell from more than one storefront and just want to know what sold today without opening three dashboards or copying numbers into a spreadsheet.
        Start with built-in demo data, then unlock Pro to connect your own provider accounts. SaneSales talks directly to each provider from your device, so SaneApps never receives your sales data, customer list, products, orders, revenue, or API keys.

        On Mac, SaneSales gives you a fast desktop dashboard, menu bar revenue, widgets, order search, product breakdowns, refund-aware totals, custom date ranges, and CSV export.

        Demo includes:
        • Built-in sample dashboard
        • Sample orders and product catalog
        • Built-in demo mode

        Pro unlocks:
        • Live sales tracking
        • iCloud Keychain provider sync across your Apple devices
        • Custom date ranges
        • Full order history
        • CSV export
        • Desktop widgets and menu bar totals
        • Multiple providers at once
      keywords: "lemon squeezy,gumroad,stripe,revenue,orders,sales,refunds,merchant,menu bar"
      whats_new: "Critical security update."
      marketing_url: "https://sanesales.com"
    ios:
      subtitle: "Private Revenue Tracker"
      promotional_text: "Track Lemon Squeezy, Gumroad, and Stripe in one private native app. Try demo data first, then unlock Pro for live sales."
      description: >-
        Track Lemon Squeezy, Gumroad, and Stripe revenue on iPhone, iPad, and Apple Watch in one private native app for indie sellers.

        SaneSales is built for makers who sell from more than one storefront and just want to know what sold today without opening three dashboards or copying numbers into a spreadsheet.
        Start with built-in demo data, then unlock Pro to connect your own provider accounts. SaneSales talks directly to each provider from your device, so SaneApps never receives your sales data, customer list, products, orders, revenue, or API keys.

        On iPhone, iPad, and Apple Watch, SaneSales gives you a quick revenue dashboard, widgets, order search, product breakdowns, refund-aware totals, custom date ranges, and CSV export.

        Demo includes:
        • Built-in sample dashboard
        • Sample orders and product catalog
        • Built-in demo mode

        Pro unlocks:
        • Live sales tracking
        • iCloud Keychain provider sync across your Apple devices
        • Custom date ranges
        • Full order history
        • CSV export
        • Multiple providers at once
        • Shared Pro access across your Apple devices
      keywords: "lemon squeezy,gumroad,stripe,revenue,orders,sales,refunds,widgets,watch"
      whats_new: "Critical security update."
      marketing_url: "https://sanesales.com"
  review_notes: "SaneSales is a freemium, read-only App Store app for merchants with existing LemonSqueezy, Gumroad, or Stripe accounts. Basic is free in the App Store build and includes built-in demo mode, so App Review does not need an account, API key, or payment. Live provider connections require Pro. SaneSales Pro is the only paid app unlock and is sold as a one-time StoreKit In-App Purchase through the Unlock Pro button in onboarding or Settings > License. There is no website license flow, no license key flow, no account signup, and no external checkout flow in the App Store build."
  review_notes_by_platform:
    macos: >-
      Basic is free in the App Store build and includes built-in demo mode. No account required. No API key required. No payment is required for the reviewer path. Live provider connections require Pro. The Pro unlock path is StoreKit only: use Unlock Pro from onboarding or Settings > License. There is no website license flow, no license key flow, and no external checkout flow in the App Store build.
      Fastest review path:
      1. Launch SaneSales.
      2. On the final onboarding screen, click “Try Demo Data”.
      3. Review the dashboard, orders, products, and recent snapshot using the fictional local demo data.
      4. To review the optional Pro unlock, click “Unlock Pro” on the welcome screen before choosing demo mode or connecting a provider.
      5. If onboarding has already been dismissed, open Settings and select the License tab.
      Demo includes:
      - Fictional dashboard snapshot.
      - Fictional orders and product catalog.
      - Built-in demo mode.
      Pro adds:
      - Live sales tracking.
      - Custom date ranges.
      - Full order history.
      - CSV export.
      - Multiple providers at once.
      - Desktop widgets and menu bar totals.
      Business model:
      - Users are merchants and creators with existing merchant accounts on LemonSqueezy, Gumroad, or Stripe.
      - Those external merchant accounts are purchased outside the app with LemonSqueezy, Gumroad, or Stripe.
      - SaneSales only reads the user's own sales data: orders, products, refunds, and revenue analytics from those optional existing accounts.
      - Built-in demo dashboard access is included with the free app download. Live tracking requires Pro.
      - The only paid app unlock in the App Store build is SaneSales Pro, a one-time non-consumable StoreKit In-App Purchase.
      - Non-IAP app unlocks: none.
      - No paid digital content exists in the app beyond the optional Pro unlock.
      - No non-IAP app unlocks exist. Connecting a provider does not unlock paid app features.
      - No account signup is required. No fee to create an account inside SaneSales exists because SaneSales has no account system.
      - This is not an enterprise service.
      - There are no license keys and no external checkout links intended for the App Store build.
      - Connecting LemonSqueezy, Gumroad, or Stripe is optional and requires the StoreKit Pro unlock for live tracking.
    ios: >-
      Basic is free in the App Store build and includes built-in demo mode. No account required. No API key required. No payment is required for the reviewer path. Live provider connections require Pro. The Pro unlock path is StoreKit only: use Unlock Pro from onboarding or Settings > License. There is no website license flow, no license key flow, and no external checkout flow in the App Store build.
      Fastest review path:
      1. Launch SaneSales on iPhone or iPad.
      2. On the onboarding screen, tap “Try Demo Data”. If onboarding has already been dismissed, go to Settings > Data > Enable Demo Mode.
      3. Review the dashboard, orders, products, and provider filters using the fictional local demo data.
      4. To review the optional Pro unlock, tap “Unlock Pro” on the setup screen, or open the Settings tab and use the License section.
      Apple Watch companion:
      - Basic shows an unlock prompt on Apple Watch. Unlock Pro on iPhone to sync live Watch data.
      Demo includes:
      - Fictional dashboard snapshot.
      - Fictional orders and product catalog.
      - Built-in demo mode.
      Pro adds:
      - Live sales tracking.
      - Custom date ranges.
      - Full order history.
      - CSV export.
      - Multiple providers at once.
      - Shared Pro access across your Apple devices.
      Business model:
      - Users are merchants and creators with existing merchant accounts on LemonSqueezy, Gumroad, or Stripe.
      - Those external merchant accounts are purchased outside the app with LemonSqueezy, Gumroad, or Stripe.
      - SaneSales only reads the user's own sales data: orders, products, refunds, and revenue analytics from those optional existing accounts.
      - Built-in demo dashboard access is included with the free app download. Live tracking requires Pro.
      - The only paid app unlock in the App Store build is SaneSales Pro, a one-time non-consumable StoreKit In-App Purchase.
      - Non-IAP app unlocks: none.
      - No paid digital content exists in the app beyond the optional Pro unlock.
      - No non-IAP app unlocks exist. Connecting a provider does not unlock paid app features.
      - No account signup is required. No fee to create an account inside SaneSales exists because SaneSales has no account system.
      - This is not an enterprise service.
      - There are no license keys and no external checkout links intended for the App Store build.
      - Connecting LemonSqueezy, Gumroad, or Stripe is optional and requires the StoreKit Pro unlock for live tracking.
  iap:
    display_name: "SaneSales Pro Unlock"
    price_usd: 24.99
    description: "Unlock Pro analytics with one purchase."
    review_note: "SaneSales Pro Unlock is a one-time non-consumable StoreKit purchase. It unlocks custom date ranges, full order history, CSV export, multiple providers, menu bar quick glance on macOS, and widgets where supported. No external checkout links or license keys are used in the App Store build."
  accessibility_declarations:
    publish: true
    families:
      iphone:
        supports_dark_interface: true
        supports_sufficient_contrast: true
        supports_larger_text: true
        supports_voiceover: true
        supports_voice_control: true
        supports_differentiate_without_color_alone: true
        supports_reduced_motion: true
        supports_captions: false
        supports_audio_descriptions: false
      ipad:
        supports_dark_interface: true
        supports_sufficient_contrast: true
        supports_larger_text: true
        supports_voiceover: true
        supports_voice_control: true
        supports_differentiate_without_color_alone: true
        supports_reduced_motion: true
        supports_captions: false
        supports_audio_descriptions: false
      mac:
        supports_dark_interface: true
    mac:
      supports_dark_interface: true
    iphone:
      supports_dark_interface: true
    ipad:
      supports_dark_interface: true
  screenshots:
    macos: Screenshots/appstore-*-dark-mac.png
    ios: Screenshots/appstore-*-dark-6.7.png
    ipad: Screenshots/appstore-*-dark-ipad.png
    watch: Screenshots/appstore-*-dark-watch.png
  strip_frameworks:
    - Sparkle.framework
  contact:
    name: "Stephan Joseph"
    phone: "+17277589785"
    email: "hi@saneapps.com"

website: true
website_domain: sanesales.com
