# SaneProcess compliance manifest
name: SaneSales
type: macos_app
scheme: SaneSales
project: SaneSales.xcodeproj
bundle_id: com.sanesales.app

build:
  xcodegen: true

tests:
  ui_dir: SaneSalesUITests
  ui_target: SaneSalesIOSUITests
  ui_scheme: SaneSalesIOS
  ui_destination: "platform=iOS Simulator,name=iPhone 17 Pro"

release:
  team_id: M78L6FXD48
  signing_identity: "Developer ID Application"
  dist_host: dist.sanesales.com
  site_host: sanesales.com
  r2_bucket: sanebar-downloads
  use_sparkle: true
  min_system_version: "14.0"
  export:
    options_plist: ExportOptions-DevID.plist
    profiles:
      - "com.sanesales.app:SaneSales Developer ID"
      - "com.sanesales.app.widgets:SaneSales Widgets Developer ID"
  archive_extra_args:
    - "-allowProvisioningUpdates"
  dmg:
    volume_icon: Resources/DMGIcon.icns
    file_icon: Resources/DMGIcon.icns
    window_size: "800 400"
    app_icon_pos: "200 185"
    drop_pos: "600 185"

commands:
  verify: ./scripts/SaneMaster.rb verify
  test_mode: ./scripts/SaneMaster.rb tm
  lint: ./scripts/SaneMaster.rb lint
  clean: ./scripts/SaneMaster.rb clean
  launch: ./scripts/SaneMaster.rb launch
  logs: ./scripts/SaneMaster.rb logs

docs:
  - CLAUDE.md
  - README.md
  - DEVELOPMENT.md
  - ARCHITECTURE.md
  - SESSION_HANDOFF.md

mcps:
  - apple-docs
  - context7
  - github
  - xcode

appstore:
  enabled: true
  app_id: "6759010976"
  product_id: "com.sanesales.app.pro.unlock.v2"
  scheme: SaneSales-AppStore
  configuration: Release-AppStore
  platforms: [macos, ios]
  ios_scheme: SaneSalesIOS
  category: public.app-category.finance
  age_rating: "4+"
  privacy_policy_url: "https://sanesales.com/privacy"
  support_url: "https://sanesales.com/support"
  marketing_url: "https://sanesales.com"
  metadata:
    macos:
      subtitle: "Read-Only Sales Dashboard"
      promotional_text: "Try demo data first. Free includes live daily sales, today's orders, and products. Pro adds custom date ranges, full history, CSV export, and multi-provider views."
      description: >-
        Track LemonSqueezy, Gumroad, and Stripe revenue in one private read-only desktop dashboard.

        No account is required to explore the app: start with built-in demo data right away, then connect your own accounts when you are ready.
        Review orders, products, refunds, and trends without bouncing between storefront tabs.

        Free includes:
        • Recent dashboard snapshot
        • Recent orders and full product catalog
        • Built-in demo mode
        • Private on-device storage

        Pro unlock adds:
        • Custom date ranges
        • Full order history
        • CSV export
        • Desktop widgets and menu bar totals
        • Multiple providers at once
      keywords: "lemonsqueezy,gumroad,stripe,revenue,analytics,orders,refunds,merchant,menubar"
      whats_new: "Adds custom date ranges for Pro, with shared Dashboard and Orders filtering, plus automatic App Store entitlement refresh after redeeming offer codes or restoring purchases."
      marketing_url: "https://sanesales.com"
    ios:
      subtitle: "Read-Only Sales Dashboard"
      promotional_text: "Try demo data first. Free includes live daily sales, today's orders, and products. Pro adds custom date ranges, full history, CSV export, and multi-provider views."
      description: >-
        Track LemonSqueezy, Gumroad, and Stripe revenue on iPhone, iPad, and Apple Watch in one private read-only dashboard.

        No account is required to explore the app: start with built-in demo data right away, then connect your own accounts when you are ready.
        Check orders, products, refunds, and trends anywhere.

        Free includes:
        • Recent dashboard snapshot
        • Recent orders and full product catalog
        • Built-in demo mode
        • Private on-device storage

        Pro unlock adds:
        • Custom date ranges
        • Full order history
        • CSV export
        • Multiple providers at once
        • Shared Pro access across your Apple devices
      keywords: "lemonsqueezy,gumroad,stripe,revenue,analytics,orders,refunds,widgets,watch"
      whats_new: "Adds custom date ranges for Pro, with shared Dashboard and Orders filtering, plus automatic App Store entitlement refresh after redeeming offer codes or restoring purchases."
      marketing_url: "https://sanesales.com"
  review_notes: "SaneSales is a freemium, read-only App Store app for merchants with existing LemonSqueezy, Gumroad, or Stripe accounts. Basic is free in the App Store build. Demo mode is available immediately, so App Review does not need an account, API key, or payment. SaneSales Pro is the only paid app unlock and is sold as a one-time StoreKit In-App Purchase. Connecting a provider is optional and does not unlock paid app features. There are no external checkout links, account signups, or license keys in the App Store build."
  review_notes_by_platform:
    macos: >-
      Basic is free in the App Store build. No account required. No API key required. No payment is required for the reviewer path. Built-in demo mode is available immediately.
      Fastest review path:
      1. Launch SaneSales.
      2. On the final onboarding screen, click “Try Demo Data”.
      3. Review the dashboard, orders, products, and recent snapshot using the fictional local demo data.
      4. To review the optional Pro unlock, click “Unlock Pro” on the welcome screen before choosing demo mode or connecting a provider.
      5. If onboarding has already been dismissed, open Settings and select the License tab.
      Free includes:
      - Recent dashboard snapshot.
      - Recent orders and full product catalog.
      - Built-in demo mode.
      Pro adds:
      - Custom date ranges.
      - Full order history.
      - CSV export.
      - Multiple providers at once.
      - Desktop widgets and menu bar totals.
      Business model:
      - Users are merchants and creators with existing merchant accounts on LemonSqueezy, Gumroad, or Stripe.
      - Those external merchant accounts are purchased outside the app with LemonSqueezy, Gumroad, or Stripe.
      - SaneSales only reads the user's own sales data: orders, products, refunds, and revenue analytics from those optional existing accounts.
      - Core dashboard access is included with the free app download.
      - The only paid app unlock in the App Store build is SaneSales Pro, a one-time non-consumable StoreKit In-App Purchase.
      - Non-IAP app unlocks: none.
      - No paid digital content exists in the app beyond the optional Pro unlock.
      - No non-IAP app unlocks exist. Connecting a provider does not unlock paid app features.
      - No account signup is required. No fee to create an account inside SaneSales exists because SaneSales has no account system.
      - This is not an enterprise service.
      - There are no license keys and no external checkout links intended for the App Store build.
      - Connecting LemonSqueezy, Gumroad, or Stripe is optional and does not unlock paid app features or digital content.
    ios: >-
      Basic is free in the App Store build. No account required. No API key required. No payment is required for the reviewer path. Built-in demo mode is available immediately.
      Fastest review path:
      1. Launch SaneSales on iPhone or iPad.
      2. On the onboarding screen, tap “Try Demo Data”. If onboarding has already been dismissed, go to Settings > Data > Enable Demo Mode.
      3. Review the dashboard, orders, products, and provider filters using the fictional local demo data.
      4. To review the optional Pro unlock, tap “Unlock Pro” on the setup screen, or open the Settings tab and use the License section.
      Apple Watch companion:
      - Open the companion watch app after enabling demo mode on iPhone, or tap “Show Demo Data” directly on Apple Watch.
      Free includes:
      - Recent dashboard snapshot.
      - Recent orders and full product catalog.
      - Built-in demo mode.
      Pro adds:
      - Custom date ranges.
      - Full order history.
      - CSV export.
      - Multiple providers at once.
      - Shared Pro access across your Apple devices.
      Business model:
      - Users are merchants and creators with existing merchant accounts on LemonSqueezy, Gumroad, or Stripe.
      - Those external merchant accounts are purchased outside the app with LemonSqueezy, Gumroad, or Stripe.
      - SaneSales only reads the user's own sales data: orders, products, refunds, and revenue analytics from those optional existing accounts.
      - Core dashboard access is included with the free app download.
      - The only paid app unlock in the App Store build is SaneSales Pro, a one-time non-consumable StoreKit In-App Purchase.
      - Non-IAP app unlocks: none.
      - No paid digital content exists in the app beyond the optional Pro unlock.
      - No non-IAP app unlocks exist. Connecting a provider does not unlock paid app features.
      - No account signup is required. No fee to create an account inside SaneSales exists because SaneSales has no account system.
      - This is not an enterprise service.
      - There are no license keys and no external checkout links intended for the App Store build.
      - Connecting LemonSqueezy, Gumroad, or Stripe is optional and does not unlock paid app features or digital content.
  iap:
    display_name: "SaneSales Pro Unlock"
    price_usd: 24.99
    description: "Unlock Pro analytics with one purchase."
    review_note: "SaneSales Pro Unlock is a one-time non-consumable StoreKit purchase. It unlocks custom date ranges, full order history, CSV export, multiple providers, menu bar quick glance on macOS, and widgets where supported. No external checkout links or license keys are used in the App Store build."
  accessibility_declarations:
    publish: true
    mac:
      supports_dark_interface: true
    iphone:
      supports_dark_interface: true
    ipad:
      supports_dark_interface: true
  screenshots:
    macos: Screenshots/appstore-*-dark-mac.png
    ios: Screenshots/appstore-*-dark-6.7.png
    ipad: Screenshots/appstore-*-dark-ipad.png
    watch: Screenshots/appstore-*-dark-watch.png
  strip_frameworks:
    - Sparkle.framework
  contact:
    name: "Stephan Joseph"
    phone: "+17277589785"
    email: "hi@saneapps.com"

website: true
website_domain: sanesales.com
