  "strings" : {
    "sanesales.settings.appearance.availability_hint" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaneSales bleibt immer entweder im Dock oder in der Menüleiste verfügbar, damit du es wieder öffnen kannst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaneSales always keeps either the Dock or menu bar available so you can reopen it."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SaneSales は Dock かメニューバーのどちらかから必ず開き直せるようにしています。"
          }
        }
      }
    },
